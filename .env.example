# ============================================
# KOVAS App — Variables d'environnement
# ============================================
# Copier ce fichier en .env.local pour dev, et configurer
# les variables dans Vercel pour prod.
# JAMAIS commit .env.local ou .env (cf. .gitignore).

# ============================================
# Supabase (eu-west-3 Paris)
# ============================================
# Cf. docs/credentials-setup/nexus-1993-identity.md
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JAMAIS exposer service_role_key dans le bundle client !

# ============================================
# Anthropic Claude API (3 workspaces : dev/staging/prod)
# ============================================
ANTHROPIC_API_KEY=sk-ant-...
# Model IDs (pin dated snapshots in prod)
ANTHROPIC_MODEL_VOICE=claude-haiku-4-5
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6
ANTHROPIC_MODEL_CHAT=claude-haiku-4-5
# Mode Capture-First V1.5 — Haiku rapide + low cost pour vision photos terrain
# (distinct de ANTHROPIC_MODEL_VISION qui sert pour les documents Sonnet)
ANTHROPIC_VISION_MODEL=claude-haiku-4-5
# Mode Capture-First V1.5 — Sonnet pour la consolidation finale du dossier
# (1 seul appel qui prend TOUT le contexte : photos+analyses, voice notes, text, OCR)
ANTHROPIC_CONSOLIDATION_MODEL=claude-sonnet-4-6

# ============================================
# OpenAI (Whisper transcription)
# ============================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL_TRANSCRIBE=gpt-4o-mini-transcribe

# ============================================
# Deepgram (fallback Whisper, EU Frankfurt)
# ============================================
DEEPGRAM_API_KEY=...

# ============================================
# Stripe (test mode au démarrage, Live post-vérification KBis)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Resend (emails transactionnels)
# ============================================
RESEND_API_KEY=re_...
RESEND_FROM=noreply@kovas.fr

# ============================================
# Brevo SMS (rappels client J-1 + relances follow-up SMS)
# ============================================
BREVO_API_KEY=xkeysib-...
# Émetteur SMS (max 11 caractères alphanumériques, validé Brevo console)
BREVO_SMS_SENDER=KOVAS

# ============================================
# PostHog (analytics + feature flags + session replay)
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ============================================
# Sentry (error tracking)
# ============================================
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=nexus-1993
SENTRY_PROJECT=kovas-web

# ============================================
# Liciel MDB Writer microservice (Java/Jackcess, Railway)
# ============================================
MDB_WRITER_URL=https://kovas-mdb-writer.up.railway.app
MDB_WRITER_API_KEY=...

# ============================================
# Google APIs (pour bouton "Partager 3 modes" feature #8 MVP V1)
# ============================================
GOOGLE_OAUTH_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_SECRET=...
GOOGLE_OAUTH_REDIRECT_URI=https://kovas.fr/api/auth/google/callback

# ============================================
# Dropbox OAuth (option mode 2 "Partager vers Liciel")
# ============================================
DROPBOX_APP_KEY=...
DROPBOX_APP_SECRET=...

# ============================================
# Public URLs
# ============================================
NEXT_PUBLIC_APP_URL=https://kovas.fr
NEXT_PUBLIC_API_URL=https://kovas.fr/api

# ============================================
# Env runtime
# ============================================
NODE_ENV=development

# ============================================
# Dev local uniquement — préremplissage page /login (jamais en prod)
# ============================================
# Créez d'abord le compte via /signup avec le même email + mot de passe.
# Email : domaine « pro » requis (pas gmail/yahoo). Ex. @kovas-e2e.fr
KOVAS_DEV_LOGIN_PREFILL_EMAIL=dev@kovas-e2e.fr
KOVAS_DEV_LOGIN_PREFILL_PASSWORD=DevTest1234!

# 1 = autorise GET /api/dev/enter (connexion auto + création compte dev si besoin). Jamais en prod.
KOVAS_DEV_ENTER=1

# ============================================
# Dashboard Admin (itération 1) — /admin + bot Telegram à venir
# ============================================
# Clef de chiffrement AES-256-GCM des secrets TOTP en BDD + HMAC du cookie 2FA.
# Génération initiale :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 32 bytes = 64 caractères hex. JAMAIS commit cette valeur.
ADMIN_2FA_ENCRYPTION_KEY=

# Secret partagé entre Vercel Cron et /api/cron/* (alert engine itération 8).
# Vercel envoie automatiquement `Authorization: Bearer ${CRON_SECRET}` aux
# routes définies dans vercel.json.crons. À configurer dans Vercel
# Environment Variables (production + preview).
# Génération :
#   openssl rand -hex 32
CRON_SECRET=

# Secret optionnel séparé pour les endpoints internes (Edge → Next.js).
# Si non défini, fallback sur CRON_SECRET. Utilisé par /api/internal/ghost-notify
# pour éviter d'exposer le CRON_SECRET principal aux Edge Functions tierces.
INTERNAL_CRON_SECRET=

# ============================================
# Google reCAPTCHA v3 — anti-spam leads B2C (Mission K1)
# ============================================
# Site Key (publique, exposée côté client) — créée dans la Google reCAPTCHA console
# https://www.google.com/recaptcha/admin (v3, domaine kovas.fr + localhost).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Secret Key (server-only — NE JAMAIS exposer côté client). Utilisée par
# /api/diagnosticians/[id]/quote-request pour appeler https://www.google.com/recaptcha/api/siteverify.
# Si absente : mode dev permissif (bypass + warning Sentry).
RECAPTCHA_SECRET_KEY=

# ============================================
# Bot Telegram admin (itération 12 — KOVAS admin bot)
# ============================================
# Token reçu depuis @BotFather lors de la création du bot.
TELEGRAM_BOT_TOKEN=

# Modèle Claude utilisé par le NLP du bot Telegram (itération 13/N).
# Défaut : claude-haiku-4-5 (rapide + low cost, ~0,0001€ / message).
ANTHROPIC_BOT_MODEL=claude-haiku-4-5

# Secret HMAC partagé Telegram ↔ /api/telegram/webhook
# Génération : openssl rand -hex 32
# Configuré lors du `node scripts/telegram-setup-webhook.mjs`.
TELEGRAM_WEBHOOK_SECRET=

# Optionnel : chat_id Telegram perso de l'admin (debug, ping outils)
TELEGRAM_ADMIN_USER_ID=

# Chat_ids des channels Telegram dédiés (créés via @BotFather + bot ajouté en admin)
# Notifications push V1 : signups quotidiens / revenue events / alertes / erreurs
TELEGRAM_CHAT_ID_SIGNUPS=
TELEGRAM_CHAT_ID_REVENUE=
TELEGRAM_CHAT_ID_ALERTS=
TELEGRAM_CHAT_ID_ERRORS=

# Secret partagé pour /api/telegram/send (notifications internes : alert engine,
# cron, broadcasts). JAMAIS exposé côté client.
# Génération : openssl rand -hex 32
INTERNAL_API_SECRET=

# ============================================
# Scheduling (Phase A — durée + geocoding + routing + quota DPE)
# ============================================
# OpenRouteService : routes routières précises (driving-car).
# Si vide → fallback Haversine maison (× 1.3 / 50km/h, suffisant V1).
# Inscription gratuite : https://openrouteservice.org (quota 2000 req/jour).
OPENROUTESERVICE_API_KEY=

# Buffer de transition par défaut entre missions (rangement, briefing, etc.).
# Surchargé par user_preferences.scheduling_buffer_minutes si défini.
SCHEDULING_BUFFER_DEFAULT_MIN=25

# Limite légale FR : 1000 DPE/an/diagnostiqueur (article R134-4-3 CC).
# Surcharge utile pour tests internes uniquement.
DPE_ANNUAL_LIMIT=1000

# TTL cache routes_cache (trafic varie, contrairement au geocoding permanent).
ROUTES_CACHE_TTL_SECONDS=3600

# ============================================
# Pricing (Partition B — calculateur de prix indicatif)
# ============================================
# Taux TVA par défaut appliqué lors de l'application d'un template tarifaire.
# 0.20 = 20% (taux normal France).
PRICING_DEFAULT_VAT_RATE=0.20
# Template par défaut suggéré au user lors de l'onboarding pricing.
# Valeurs : economique | median | premium
PRICING_DEFAULT_TEMPLATE=median

# ============================================
# Inbound email webhook (Brevo Inbound Parsing → /inbound-email-process)
# ============================================
# Secret partagé avec Brevo (header X-Brevo-Webhook-Signature). Génération :
#   openssl rand -hex 32
# Configurer la même valeur dans la console Brevo (Inbound Parsing → Webhook).
# TODO admin : configurer les MX records sur kovas.fr (MX 10 in1-mxa.bind.brevo.com /
# MX 20 in2-mxb.bind.brevo.com) + DNS catch-all sur devis-*@kovas.fr.
# Doc complète : docs/open-data-integrations.md
BREVO_INBOUND_WEBHOOK_SECRET=

# Modèle Claude utilisé pour l'extraction IA des emails entrants (tool use).
# Défaut : claude-haiku-4-5 (rapide, ~0,002€ par email).
ANTHROPIC_MODEL_INBOUND=claude-haiku-4-5

# Modèle Claude utilisé pour l'anonymisation RGPD des cas communauté.
# Défaut : claude-haiku-4-5 (NER + reformulation).
ANTHROPIC_MODEL_ANONYMIZE=claude-haiku-4-5

# ============================================
# Open data publiques FR (overrides — utiles pour tests/staging)
# ============================================
# BAN (Base Adresse Nationale) — gratuit, sans clé, ~50 req/s/IP.
BAN_API_BASE_URL=https://api-adresse.data.gouv.fr

# Cadastre IGN (apicarto.ign.fr) — gratuit, sans clé.
CADASTRE_API_BASE_URL=https://apicarto.ign.fr

# BDNB (Base de Données Nationale des Bâtiments CSTB) — gratuit, clé optionnelle.
# TODO admin : si rate limit en prod, demander une clé sur https://bdnb.io
# et configurer BDNB_API_KEY.
BDNB_API_BASE_URL=https://api.bdnb.io
BDNB_API_KEY=

# RNB (Référentiel National des Bâtiments) — gratuit, alpha.
RNB_API_BASE_URL=https://rnb-api.beta.gouv.fr

# Géorisques (georisques.gouv.fr) — gratuit, sans clé.
GEORISQUES_API_BASE_URL=https://www.georisques.gouv.fr/api/v1

# DVF (Demandes de Valeurs Foncières) — mirroir community Etalab.
DVF_API_BASE_URL=https://api.cquest.org/dvf

# ============================================
# Quotas & AI usage tracking (Edge Functions quota-tracker / ai-usage-tracker)
# ============================================
# IDs des modèles utilisés (idem ANTHROPIC_MODEL_* ci-dessus, doublonnés pour
# rendre la grille tarifaire explicite et facilement éditable).
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_OPUS_MODEL=claude-opus-4-7

# Grille tarifaire USD par MTok (1 000 000 tokens). Mise à jour mai 2026.
# Modifier sans redéploiement quand Anthropic / OpenAI / Deepgram bougent.
ANTHROPIC_PRICING_HAIKU_INPUT_USD_PER_MTOK=1
ANTHROPIC_PRICING_HAIKU_OUTPUT_USD_PER_MTOK=5
ANTHROPIC_PRICING_HAIKU_CACHED_USD_PER_MTOK=0.1
ANTHROPIC_PRICING_HAIKU_CACHE_WRITE_USD_PER_MTOK=1.25
ANTHROPIC_PRICING_SONNET_INPUT_USD_PER_MTOK=3
ANTHROPIC_PRICING_SONNET_OUTPUT_USD_PER_MTOK=15
ANTHROPIC_PRICING_SONNET_CACHED_USD_PER_MTOK=0.3
ANTHROPIC_PRICING_SONNET_CACHE_WRITE_USD_PER_MTOK=3.75
ANTHROPIC_PRICING_OPUS_INPUT_USD_PER_MTOK=15
ANTHROPIC_PRICING_OPUS_OUTPUT_USD_PER_MTOK=75
ANTHROPIC_PRICING_OPUS_CACHED_USD_PER_MTOK=1.5
ANTHROPIC_PRICING_OPUS_CACHE_WRITE_USD_PER_MTOK=18.75
OPENAI_PRICING_WHISPER_USD_PER_MIN=0.006
OPENAI_PRICING_EMBED_SMALL_USD_PER_MTOK=0.02
DEEPGRAM_PRICING_NOVA3_USD_PER_MIN=0.0043

# Taux de change USD → EUR (mis à jour manuellement, ~1× par trimestre).
USD_TO_EUR_RATE=0.92

# ─── Optimisation coûts IA (Vague Cost Optimization 2026-05) ───
# Modèle dédié au chatbot méthodo RAG (regulatory-ai-chat). Sonnet 4.6 par défaut
# (qualité citation), Haiku 4.5 acceptable en fallback pour A/B test.
ANTHROPIC_MODEL_REG_CHAT=claude-sonnet-4-6

# Nombre max de documents soumis dans un seul batch Anthropic (regulatory-batch-analyze).
# Cap technique Anthropic = 100 000, cap KOVAS = 1000 (largement assez pour la veille FR).
REGULATORY_BATCH_MAX_DOCS=1000

# Email admin pour alertes critiques (overflow-billing échec Stripe, etc.).
KOVAS_ADMIN_EMAIL=benjamin@kovas.fr

# ─── Identité société éditrice (documentaire) ───
# Ces variables ne sont PAS lues directement par le code Next.js : la source unique
# de vérité est `apps/web/src/lib/legal/company-identity.ts` (constante
# `COMPANY_IDENTITY`). Elles sont documentées ici pour les scripts admin / edge
# functions qui auraient besoin de ces valeurs (ex : génération PDF batch, hooks
# externes facture).
COMPANY_LEGAL_NAME="NEXUS 1993"
COMPANY_SIRET="98278615400012"
COMPANY_SIREN="982786154"
COMPANY_VAT="FR18982786154"
COMPANY_RCS="982 786 154 R.C.S. Paris"
COMPANY_APE_CODE="58.29C"
COMPANY_ADDRESS_LINE1="66 Avenue des Champs Élysées"
COMPANY_ADDRESS_POSTAL_CODE="75008"
COMPANY_ADDRESS_CITY="Paris"
