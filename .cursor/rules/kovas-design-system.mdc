  }

  body {
    @apply font-display text-ink antialiased;
    font-weight: 400;
  }
}

@layer utilities {
  .glass {
    background: linear-gradient(135deg, rgba(255,255,255,0.50) 0%, rgba(255,255,255,0.25) 100%);
    border: 1px solid rgba(255,255,255,0.65);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    box-shadow: var(--shadow-glass, inset 0 1px 0 rgba(255,255,255,0.9), 0 12px 36px rgba(22,49,68,0.10));
  }

  .glass-opaque {
    background: linear-gradient(135deg, rgba(255,255,255,0.85) 0%, rgba(255,255,255,0.70) 100%);
    border: 1px solid rgba(255,255,255,0.9);
    backdrop-filter: blur(24px) saturate(1.2);
    -webkit-backdrop-filter: blur(24px) saturate(1.2);
  }

  .glass-dark {
    background: linear-gradient(135deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.04) 100%);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
  }
}
