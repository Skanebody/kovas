### 4.4 Composant Card

```tsx
// components/ui/Card.tsx
import { forwardRef, type HTMLAttributes } from 'react'
import { cva, type VariantProps } from 'class-variance-authority'
import { cn } from '@/lib/utils'

const cardVariants = cva(
  'rounded-lg transition-all duration-base ease-spring',
  {
    variants: {
      variant: {
        glass: 'glass',
        opaque: 'glass-opaque',
        dark: 'glass-dark text-paper',
        navy: 'bg-navy text-paper shadow-[0_16px_40px_rgba(22,49,68,0.25)] relative overflow-hidden',
        warm: 'border border-amber/20 shadow-md',
      },
      padding: {
        sm: 'p-5',     // 20px
        default: 'p-7', // 28px
        lg: 'p-9',     // 36px
      },
    },
    defaultVariants: {
      variant: 'opaque',
      padding: 'default',
    },
  }
)

export interface CardProps
  extends HTMLAttributes<HTMLDivElement>,
    VariantProps<typeof cardVariants> {}

export const Card = forwardRef<HTMLDivElement, CardProps>(
  ({ className, variant, padding, style, ...props }, ref) => {
    const warmStyle = variant === 'warm'
      ? { background: 'linear-gradient(135deg, rgba(255,213,168,0.80), rgba(255,200,150,0.65))' }
      : undefined
    return (
      <div
        ref={ref}
        className={cn(cardVariants({ variant, padding }), className)}
        style={{ ...warmStyle, ...style }}
        {...props}
      />
    )
  }
)
Card.displayName = 'Card'
```

