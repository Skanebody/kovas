{
  "name": "@kovas/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "postbuild": "echo 'sitemap generated by app/sitemap.xml/route.ts (next-sitemap deprecated)'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:rls": "vitest run tests/rls --no-coverage",
    "test:a11y": "playwright test --project=a11y",
    "test:all": "pnpm test:unit && pnpm test:e2e && pnpm test:a11y",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes --build-script-name=storybook:build"
  },
  "dependencies": {
